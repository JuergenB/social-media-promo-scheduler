    {
      "parameters": {
        "formTitle": "The Intersect Social Post Generator V 1.2",
        "formDescription": "Enter the issue preview URL, as well as the issue number, and this workflow will create a set of social media posts in our Intersect Airtable.",
        "formFields": {
          "values": [
            {
              "fieldLabel": "Issue URL",
              "placeholder": "https://",
              "requiredField": true
            },
            {
              "fieldLabel": "Issue Number",
