    {
      "parameters": {
        "jsCode": "// Get input items (should just be one, with .json.data as the array)\nconst items = $input.all();\nconst dataArray = items[0].json.data;\n\nlet result = [];\nfunction formatTone(arr) { return arr ? arr.join(', ') : 'N/A'; }\n\nfor (const p of dataArray) {\n  result.push(\n    `Platform: ${p.Platform_Post_Type}\n- Ideal Length: ${p.Ideal_Length || p.Max_Characters || 'N/A'}\n- URL Recommendation: ${p.URL_Recommendation}\n- Tone: ${formatTone(p.Tone)}\n- Use Case: ${p.Primary_Use_Case}\n- Engagement Notes: ${p.Engagement_Notes}\n- Hashtag Limit: ${p.Hashtag_Limit}\\n`\n  );\n}\n\nreturn [{ json: { textInstructions: result.join('\\n') } }];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
