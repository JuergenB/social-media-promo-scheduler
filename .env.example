# ─── Core ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3025
NEXT_PUBLIC_APP_NAME=PolyWiz

# ─── Auth (Auth.js v5) ─────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=your_auth_secret_here
# Format: id:email:password:displayName:role (comma-separated, roles: admin, curator, viewer)
AUTH_USERS=1:you@example.com:password:Your Name:admin

# ─── Social Media Scheduling ──────────────────────────
# Zernio API — schedules and publishes to 14 platforms
# Get key at: https://zernio.com/dashboard/api-keys
# Global fallback (used when brand has no specific key)
LATE_API_KEY=sk_your_zernio_api_key_here

# Per-brand Zernio keys (referenced by Brand.zernioApiKeyLabel in Airtable)
# LATE_API_KEY_INTERSECT=sk_xxx   # The Intersect
# LATE_API_KEY_SUGAR_PRESS=sk_xxx # Sugar Press Art
# LATE_API_KEY_NRA=sk_xxx         # Not Real Art
# LATE_API_KEY_ARTSVILLE=sk_xxx   # Artsville USA

# ─── Data Storage ─────────────────────────────────────
# Airtable — campaigns, posts, brands, platform settings
# Get PAT at: https://airtable.com/create/tokens (needs data.records:read, data.records:write, schema.bases:read)
AIRTABLE_API_KEY=pat_your_airtable_pat_here
AIRTABLE_BASE_ID=app_your_base_id_here

# ─── Content Extraction ───────────────────────────────
# Firecrawl — web scraping and structured data extraction
# Get key at: https://firecrawl.dev
FIRECRAWL_API_KEY=fc-your_key_here

# ─── Research & Enrichment ────────────────────────────
# Perplexity — deep research for artist bios, exhibition context
# Get key at: https://perplexity.ai/settings/api
PERPLEXITY_API_KEY=pplx-your_key_here

# ─── Content Generation ──────────────────────────────
# Anthropic — primary model for post generation (Claude Sonnet 4.6)
# Get key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Per-brand Anthropic keys (referenced by Brand.anthropicApiKeyLabel in Airtable)
# ANTHROPIC_KEY_INTERSECT=sk-ant-xxx   # The Intersect + Polymash
# ANTHROPIC_KEY_ARTERIAL=sk-ant-xxx    # Arterial.org brands (Not Real Art, Artsville, etc.)

# OpenAI — alternative/fallback model (GPT-4.1-mini)
# Get key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_key_here

# ─── Link Shortening & Analytics ─────────────────────
# Short.io — shortened links with click tracking and per-platform UTM params
# Get key at: https://short.io (Settings → Integrations → API Key)
# Global fallback (used when brand has no specific key/domain)
SHORT_IO_API_KEY=your_short_io_key_here
SHORT_IO_DOMAIN=your-short-domain.link

# Per-brand Short.io keys (referenced by Brand.shortApiKeyLabel in Airtable)
# Create domain-restricted API keys in Short.io for each domain
# SHORT_IO_KEY_INTERSECT=sk_xxx   # jb9.me (The Intersect)
# SHORT_IO_KEY_ARTERIAL=sk_xxx    # artsy.short.gy (Arterial.org brands: Not Real Art, Artsville, etc.)

# ─── Image Generation ────────────────────────────────
# Replicate — AI image generation (Flux Schnell/Dev)
# Get key at: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_your_replicate_token_here

# ─── Visual Content / Carousels ──────────────────────
# Blotato — carousel and visual content creation
# BLOTATO_API_KEY=your_blotato_key_here

# Orshot — Instagram carousel templates
# ORSHOT_API_KEY=your_orshot_key_here

# ─── Link-in-Bio ─────────────────────────────────────
# LNK.bio — link-in-bio pages (especially for Instagram)
# LNKBIO_API_KEY=your_lnkbio_key_here
