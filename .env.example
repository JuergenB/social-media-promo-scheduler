# ===================================================================
# PolyWiz — Environment Variables
# ===================================================================
# Grouped by service. Per-brand keys are referenced via Airtable Brand
# records (e.g., Brand.zernioApiKeyLabel → LATE_API_KEY_INTERSECT).
# ===================================================================

# === App Identity ===================================================
# Public URL and display name (used in metadata, OAuth callbacks)
NEXT_PUBLIC_APP_URL=http://localhost:3025
NEXT_PUBLIC_APP_NAME=PolyWiz

# === Authentication (Auth.js v5) ====================================
# Session encryption secret — generate with: openssl rand -base64 32
AUTH_SECRET=your_auth_secret_here
# Credential-based users — format: id:email:password:displayName:role (comma-separated)
# Roles: admin, curator, viewer
AUTH_USERS=1:you@example.com:password:Your Name:admin

# === Airtable (Data Storage) ========================================
# Personal Access Token — create at https://airtable.com/create/tokens
# Scopes needed: data.records:read, data.records:write, schema.bases:read
AIRTABLE_API_KEY=pat_your_airtable_pat_here
# Base ID for the PolyWiz Airtable base (Brands, Campaigns, Posts, etc.)
AIRTABLE_BASE_ID=app_your_base_id_here

# === Zernio API (Social Media Scheduling) ===========================
# Schedules and publishes to 14 platforms via https://zernio.com
# Get key at: https://zernio.com/dashboard/api-keys
# Global fallback (used when brand has no specific key)
LATE_API_KEY=sk_your_zernio_api_key_here

# Per-brand Zernio keys (referenced by Brand.zernioApiKeyLabel in Airtable)
# LATE_API_KEY_INTERSECT=sk_xxx   # The Intersect
# LATE_API_KEY_SUGAR_PRESS=sk_xxx # Sugar Press Art
# LATE_API_KEY_NRA=sk_xxx         # Not Real Art
# LATE_API_KEY_ARTSVILLE=sk_xxx   # Artsville USA

# === Anthropic (Content Generation — Claude Sonnet 4.6) =============
# Primary AI model for post generation
# Get key at: https://console.anthropic.com/settings/keys
# Global fallback (used when brand has no specific key)
ANTHROPIC_API_KEY=sk-ant-your_key_here

# OpenAI (used for embeddings, evaluation, or fallback models)
# Get key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your_key_here

# Per-brand Anthropic keys (referenced by Brand.anthropicApiKeyLabel in Airtable)
# ANTHROPIC_KEY_INTERSECT=sk-ant-xxx   # The Intersect + Polymash
# ANTHROPIC_KEY_ARTERIAL=sk-ant-xxx    # Arterial.org brands (Not Real Art, Artsville, etc.)

# === Firecrawl (Web Scraping) =======================================
# Scrapes campaign source URLs (newsletters, exhibitions, blog posts)
# Get key at: https://firecrawl.dev
FIRECRAWL_API_KEY=fc-your_key_here

# === Replicate (AI Image Optimization) ==============================
# AI outpainting for image aspect ratio correction (Flux Schnell/Dev)
# Get key at: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_your_replicate_token_here

# === Short.io (Link Shortening & Analytics) =========================
# Shortened links with click tracking and per-platform UTM params
# Get key at: https://short.io (Settings → Integrations → API Key)
# Global fallback (used when brand has no specific key/domain)
SHORT_IO_API_KEY=your_short_io_key_here
SHORT_IO_DOMAIN=your-short-domain.link

# Per-brand Short.io keys (referenced by Brand.shortApiKeyLabel in Airtable)
# Create domain-restricted API keys in Short.io for each domain
# SHORT_IO_KEY_INTERSECT=sk_xxx   # jb9.me (The Intersect)
# SHORT_IO_KEY_ARTERIAL=sk_xxx    # artsy.short.gy (Arterial.org brands)

# === LNK.bio (Link-in-Bio for Instagram) ============================
# OAuth2 client credentials — auto-creates link-in-bio entries after Instagram publish
# Register app at: https://lnk.bio/developer
LNKBIO_CLIENT_ID=your_client_id_here
# Secret is base64-encoded to avoid dotenv issues with special chars ($, %, {, etc.)
LNKBIO_CLIENT_SECRET_B64=your_base64_encoded_secret_here

# === Vercel Blob (Image Storage) ====================================
# Permanent public image hosting for campaign/post images
# Auto-provisioned via Vercel dashboard (Settings → Blob Stores)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_your_token_here

